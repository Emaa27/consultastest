generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model agenda_semanal {
  agenda_id      Int                   @id @default(autoincrement())
  profesional_id Int
  dia_semana     Int                   @db.TinyInt
  hora_inicio    DateTime              @db.Time(0)
  hora_fin       DateTime              @db.Time(0)
  slot_min       Int                   @db.SmallInt
  estado         agenda_semanal_estado @default(activo)
  profesionales  profesionales         @relation(fields: [profesional_id], references: [profesional_id], onDelete: Cascade, map: "fk_agenda_prof")

  @@unique([profesional_id, dia_semana, hora_inicio, hora_fin], map: "uq_agenda")
}

model consultas {
  consulta_id              Int                       @id @default(autoincrement())
  historia_id              Int
  profesional_id           Int
  fecha_consulta           DateTime                  @default(now()) @db.DateTime(0)
  motivo_consulta          String                    @db.Text
  enfermedad_actual        String?                   @db.Text
  pa_sistolica             Int?
  pa_diastolica            Int?
  frecuencia_cardiaca      Int?
  frecuencia_respiratoria  Int?
  temperatura              Decimal?                  @db.Decimal(4, 2)
  imc                      Decimal?                  @db.Decimal(4, 2)
  notas_evolucion          String?                   @db.Text
  nota_referencia          String?                   @db.Text
  consentimiento_informado Boolean                   @default(false)
  historias_clinicas       historias_clinicas        @relation(fields: [historia_id], references: [historia_id])
  profesionales            profesionales             @relation(fields: [profesional_id], references: [profesional_id])
  diagnosticos             diagnosticos[]
  pruebas_complementarias  pruebas_complementarias[]
  registro_auditoria       registro_auditoria[]

  @@index([historia_id], map: "consultas_historia_id_fkey")
  @@index([profesional_id], map: "consultas_profesional_id_fkey")
}

model diagnosticos {
  diagnostico_id            Int            @id @default(autoincrement())
  consulta_id               Int
  fecha_diagnostico         DateTime       @default(now()) @db.DateTime(0)
  juicio_clinico            String?        @db.Text
  diagnostico_presuntivo    String?        @db.Text
  diagnostico_definitivo    String?        @db.Text
  indicacion_terapeutica    String         @db.Text
  tratamiento_farmacologico String?        @db.Text
  plan_cuidados             String?        @db.Text
  recomendaciones           String?        @db.Text
  pronostico                String?        @db.VarChar(255)
  requiere_derivacion       Boolean        @default(false)
  especialidad_derivacion   String?        @db.VarChar(255)
  consultas                 consultas      @relation(fields: [consulta_id], references: [consulta_id], onDelete: Cascade)
  medicamentos              medicamentos[]

  @@index([consulta_id], map: "diagnosticos_consulta_id_fkey")
}

model historias_clinicas {
  historia_id           Int                                  @id @default(autoincrement())
  paciente_id           Int                                  @unique
  grupo_sanguineo       String?                              @db.VarChar(5)
  estado_civil          String?                              @db.VarChar(50)
  ocupacion             String?                              @db.VarChar(120)
  enfermedades_infancia String?                              @db.Text
  enfermedades_cronicas String?                              @db.Text
  cirugias              String?                              @db.Text
  alergias              String?                              @db.Text
  hospitalizaciones     String?                              @db.Text
  traumatismos          String?                              @db.Text
  medicamentos_actuales String?                              @db.Text
  consume_tabaco        Boolean                              @default(false)
  consume_alcohol       Boolean                              @default(false)
  otras_sustancias      String?                              @db.VarChar(255)
  dieta_ok              Boolean                              @default(false)
  actividad_fisica      historias_clinicas_actividad_fisica?
  habitos_sueno         historias_clinicas_habitos_sueno?
  medico_cabecera_id    Int?
  sexo                  String?                              @db.VarChar(20)
  peso                  Decimal?                             @db.Decimal(5, 2)
  altura                Decimal?                             @db.Decimal(3, 2)
  consultas             consultas[]
  profesionales         profesionales?                       @relation(fields: [medico_cabecera_id], references: [profesional_id])
  pacientes             pacientes                            @relation(fields: [paciente_id], references: [paciente_id])

  @@index([medico_cabecera_id], map: "historias_clinicas_medico_cabecera_id_fkey")
}

model obras_sociales {
  obra_social_id Int                   @id @default(autoincrement())
  nombre         String                @unique(map: "nombre") @db.VarChar(120)
  estado         obras_sociales_estado @default(activa)
  pacientes      pacientes[]
  turnos         turnos[]
}

model pacientes {
  nombre             String              @db.VarChar(120)
  apellido           String              @db.VarChar(120)
  email              String?             @unique(map: "email") @db.VarChar(120)
  telefono           String?             @db.VarChar(40)
  documento          String?             @unique(map: "documento") @db.VarChar(40)
  estado             pacientes_estado    @default(activo)
  fecha_nacimiento   DateTime?           @db.Date
  fecha_registro     DateTime?           @db.DateTime(0)
  genero             pacientes_genero?
  obra_social_id     Int?
  paciente_id        Int                 @id @default(autoincrement())
  historias_clinicas historias_clinicas?
  obras_sociales     obras_sociales?     @relation(fields: [obra_social_id], references: [obra_social_id], map: "fk_paciente_os")
  turnos             turnos[]

  @@index([obra_social_id], map: "fk_paciente_os")
}

model profesionales {
  estado             profesionales_estado @default(activo)
  matricula          String?              @db.VarChar(60)
  profesion_id       Int
  profesional_id     Int                  @id @default(autoincrement())
  usuario_id         Int                  @unique(map: "usuario_id")
  agenda_semanal     agenda_semanal[]
  consultas          consultas[]
  historias_clinicas historias_clinicas[]
  profesiones        profesiones          @relation(fields: [profesion_id], references: [profesion_id], onUpdate: Restrict, map: "fk_prof_profesion")
  usuarios           usuarios             @relation(fields: [usuario_id], references: [usuario_id], map: "fk_prof_usuario")
  turnos             turnos[]

  @@index([profesion_id], map: "ix_prof_profesion")
}

model profesiones {
  profesion_id  Int             @id @default(autoincrement())
  nombre        String          @unique(map: "nombre") @db.VarChar(80)
  profesionales profesionales[]
}

model pruebas_complementarias {
  prueba_id   Int                                 @id @default(autoincrement())
  consulta_id Int
  tipo_prueba pruebas_complementarias_tipo_prueba @default(laboratorio)
  descripcion String                              @db.VarChar(255)
  url_archivo String                              @db.VarChar(512)
  consultas   consultas                           @relation(fields: [consulta_id], references: [consulta_id], onDelete: Cascade)

  @@index([consulta_id], map: "pruebas_complementarias_consulta_id_fkey")
}

model roles {
  rol_id   Int        @id @default(autoincrement())
  nombre   String     @unique(map: "nombre") @db.VarChar(40)
  usuarios usuarios[]
}

model turnos {
  profesional_id     Int
  paciente_id        Int
  inicio             DateTime        @db.DateTime(0)
  fin                DateTime?       @db.DateTime(0)
  duracion_min       Int             @db.SmallInt
  estado             turnos_estado   @default(reservado)
  obra_social_id     Int?
  turno_id           Int             @id @default(autoincrement())
  fecha_confirmacion DateTime?       @db.DateTime(0)
  fecha_en_consulta  DateTime?       @db.DateTime(0)
  fecha_atendido     DateTime?       @db.DateTime(0)
  pacientes          pacientes       @relation(fields: [paciente_id], references: [paciente_id], map: "FK_turnos_pacientes")
  profesionales      profesionales   @relation(fields: [profesional_id], references: [profesional_id], map: "FK_turnos_profesionales")
  obras_sociales     obras_sociales? @relation(fields: [obra_social_id], references: [obra_social_id], onDelete: Restrict, map: "fk_turno_os")

  @@index([obra_social_id], map: "fk_turno_os")
  @@index([paciente_id, inicio], map: "ix_turnos_paciente")
  @@index([profesional_id, inicio], map: "ix_turnos_prof_inicio")
}

model usuarios {
  usuario_id         Int                  @id @default(autoincrement())
  nombre             String               @db.VarChar(120)
  apellido           String               @db.VarChar(120)
  email              String?              @unique(map: "email") @db.VarChar(120)
  dni                String?              @unique(map: "dni") @db.VarChar(20)
  contrasena         String               @db.VarChar(100)
  telefono           String?              @db.VarChar(40)
  rol_id             Int
  estado             usuarios_estado      @default(activo)
  profesionales      profesionales?
  registro_auditoria registro_auditoria[]
  roles              roles                @relation(fields: [rol_id], references: [rol_id], onUpdate: Restrict, map: "fk_usuarios_rol")

  @@index([rol_id], map: "fk_usuarios_rol")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model medicamentos {
  medicamento_id     Int                             @id @default(autoincrement())
  diagnostico_id     Int
  droga              String                          @db.VarChar(255)
  via_administracion medicamentos_via_administracion @default(oral)
  dosis              String                          @db.VarChar(100)
  frecuencia         String?                         @db.VarChar(100)
  diagnosticos       diagnosticos                    @relation(fields: [diagnostico_id], references: [diagnostico_id], onDelete: Cascade, map: "fk_medicamentos_diagnostico")

  @@index([diagnostico_id], map: "idx_diagnostico")
}

model registro_auditoria {
  auditoria_id   Int       @id @default(autoincrement())
  consulta_id    Int
  id_editor      Int
  version_previa String?   @db.Text
  timestamp      DateTime  @default(now()) @db.DateTime(0)
  consultas      consultas @relation(fields: [consulta_id], references: [consulta_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_regaud_consulta")
  usuarios       usuarios  @relation(fields: [id_editor], references: [usuario_id], onUpdate: Restrict, map: "fk_regaud_editor")

  @@index([consulta_id], map: "idx_regaud_consulta")
  @@index([id_editor], map: "idx_regaud_editor")
}

enum profesionales_estado {
  activo
  inactivo
}

enum obras_sociales_estado {
  activa
  inactiva
}

enum pruebas_complementarias_tipo_prueba {
  laboratorio
  imagen
  otro_estudio
}

enum pacientes_estado {
  activo
  inactivo
}

enum agenda_semanal_estado {
  activo
  inactivo
}

enum usuarios_estado {
  activo
  inactivo
}

enum pacientes_genero {
  Mujer
  Hombre
  otro
}

enum historias_clinicas_actividad_fisica {
  sedentario
  ligera
  moderada
  intensa
}

enum historias_clinicas_habitos_sueno {
  insuficiente
  normal
  excesivo
}

enum medicamentos_via_administracion {
  oral
  inyectable
  topica
  intravenosa
  intramuscular
  subcutanea
}

enum turnos_estado {
  reservado
  confirmado
  en_consulta
  atendido
  ausente
  cancelado
}
